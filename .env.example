# XMR Cheque Bot — Environment Variables
# Copy this file to .env and fill in your values (NEVER commit .env)

# Application mode: bot|monitor|both
# - bot: Telegram bot only (polling)
# - monitor: Payment monitor worker only
# - both: Run both concurrently (default for docker-compose)
APP_MODE=both

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Encryption key for view keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
VIEW_KEY_ENCRYPTION_KEY=your_fernet_key_here

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# monero-wallet-rpc URL
MONERO_RPC_URL=http://localhost:38083/json_rpc

# Optional: CoinGecko API key (free tier works without, but rate-limited)
COINGECKO_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
