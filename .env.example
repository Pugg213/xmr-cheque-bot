# XMR Cheque Bot — Environment Variables
# Copy this file to .env and fill in your values (NEVER commit .env)

# Application mode: bot|monitor|both
# - bot: Telegram bot only (polling)
# - monitor: Payment monitor worker only
# - both: Run both concurrently (default for docker-compose)
APP_MODE=both

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# monero-wallet-rpc HTTP basic auth (REQUIRED; used by docker-compose.yml)
WALLET_RPC_USER=change_me
WALLET_RPC_PASS=change_me

# Encryption key for view keys (Fernet key; 32 bytes base64)
# Safe generator (no extra deps):
#   python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
VIEW_KEY_ENCRYPTION_KEY=your_fernet_key_here

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# monero-wallet-rpc URL
MONERO_RPC_URL=http://localhost:38083/json_rpc

# Optional: CoinGecko API key (free tier works without, but rate-limited)
COINGECKO_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
